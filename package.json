{
  "name": "th0th",
  "version": "1.0.0",
  "private": true,
  "description": "th0th - Ancient knowledge keeper for modern code. Semantic search with 98% token reduction",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "bun run --filter @th0th/tools-api dev",
    "dev:mcp": "bun run --filter @th0th/mcp-client dev",
    "start:api": "bun run --filter @th0th/tools-api start",
    "start:mcp": "bun run --filter @th0th/mcp-client start",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist"
  },
  "keywords": [
    "mcp",
    "th0th",
    "thoth",
    "model-context-protocol",
    "semantic-search",
    "code-search",
    "token-optimization",
    "ai",
    "llm",
    "context",
    "vector-search",
    "knowledge-retrieval"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "bun@1.2.0"
}
