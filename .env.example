# MCP TH0TH

# Per-project data directory (set automatically by MCP server from .th0th/config.json)
# Override only if you need to point to a custom data location.
# TH0TH_DATA_DIR=/path/to/custom/data

# Database Paths (legacy, derived from TH0TH_DATA_DIR if not set)
VECTOR_DB_PATH=./data/chroma
CACHE_DB_PATH=./data/cache.db
KEYWORD_DB_PATH=./data/keyword.db

# Logging
LOG_LEVEL=info
ENABLE_METRICS=true

# Cache Configuration
L1_CACHE_MAX_SIZE=104857600  # 100MB in bytes
L1_CACHE_TTL=300             # 5 minutes
L2_CACHE_MAX_SIZE=524288000  # 500MB in bytes
L2_CACHE_TTL=3600            # 1 hour

# Compression
MIN_TOKENS_FOR_COMPRESSION=100
TARGET_COMPRESSION_RATIO=0.7  # 70% reduction

# Rate Limiting
REQUESTS_PER_MINUTE=60
TOKENS_PER_MINUTE=100000

# Security
MAX_INPUT_LENGTH=50000
SANITIZE_INPUTS=true

# ----------------------------------------------------------------------------
# Embedding Providers Configuration
# ----------------------------------------------------------------------------

# Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
OLLAMA_EMBEDDING_DIMENSIONS=768

# Mistral Embeddings
MISTRAL_API_KEY=SUA_CHAVE_AQUI
# Text embeddings - General purpose text (1024 dimensions)
MISTRAL_TEXT_EMBEDDING_MODEL=mistral-embed
# Code embeddings - Optimized for code and repositories (1536D default, up to 3072D)
MISTRAL_CODE_EMBEDDING_MODEL=codestral-embed

# Embedding cache (SHA-256 content hashing)
EMBEDDING_CACHE_DB_PATH=./data/embedding-cache.db
