# MCP TH0TH

# Database Paths
VECTOR_DB_PATH=./data/chroma
CACHE_DB_PATH=./data/cache.db
KEYWORD_DB_PATH=./data/keyword.db

# Logging
LOG_LEVEL=info
ENABLE_METRICS=true

# Cache Configuration
L1_CACHE_MAX_SIZE=104857600  # 100MB in bytes
L1_CACHE_TTL=300             # 5 minutes
L2_CACHE_MAX_SIZE=524288000  # 500MB in bytes
L2_CACHE_TTL=3600            # 1 hour

# Compression
MIN_TOKENS_FOR_COMPRESSION=100
TARGET_COMPRESSION_RATIO=0.7  # 70% reduction

# Rate Limiting
REQUESTS_PER_MINUTE=60
TOKENS_PER_MINUTE=100000

# Security
MAX_INPUT_LENGTH=50000
SANITIZE_INPUTS=true

# ----------------------------------------------------------------------------
# LLM Compression Configuration (Mistral)
# ----------------------------------------------------------------------------
# Enable LLM-based semantic compression
RLM_LLM_ENABLED=true

# Mistral API endpoint
RLM_LLM_BASE_URL=https://api.mistral.ai/v1

# Your Mistral API key from https://console.mistral.ai/
RLM_LLM_API_KEY=SUA_CHAVE_AQUI

# Model to use - Options:
# - mistral-large-latest (best quality, most expensive)
# - mistral-medium-latest (balanced)
# - mistral-small-latest (fast, cheaper)
# - codestral-latest (optimized for code)
# - open-mistral-7b (free tier available)
RLM_LLM_MODEL=mistral-small-latest

# Temperature (0.0-1.0, lower = more deterministic)
RLM_LLM_TEMPERATURE=0.2

# Max output tokens for compressed content
RLM_LLM_MAX_OUTPUT_TOKENS=800

# Timeout in milliseconds
RLM_LLM_TIMEOUT_MS=30000

# ----------------------------------------------------------------------------
# Embedding Providers Configuration
# ----------------------------------------------------------------------------

# Mistral Embeddings (Same API key as compression LLM)
# Uses the RLM_LLM_API_KEY configured above
MISTRAL_API_KEY=SUA_CHAVE_AQUI
# Text embeddings - General purpose text (1024 dimensions)
MISTRAL_TEXT_EMBEDDING_MODEL=mistral-embed
# Code embeddings - Optimized for code and repositories (1536D default, up to 3072D)
MISTRAL_CODE_EMBEDDING_MODEL=codestral-embed

# Embedding cache (SHA-256 content hashing)
EMBEDDING_CACHE_DB_PATH=./data/embedding-cache.db
